pipeline {
    agent any

    // ─── Variables globales ───────────────────────────────────────
    environment {
        PROJET     = "calculatrice-jenkins"
        VERSION    = "1.0.0"
        JAVA_HOME  = tool name: 'JDK17', type: 'jdk'   // nom configuré dans Jenkins
    }

    // ─── Options globales ─────────────────────────────────────────
    options {
        timestamps()                    // Affiche l'heure de chaque log
        timeout(time: 15, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    // ─── Déclencheurs ─────────────────────────────────────────────
    triggers {
        pollSCM('H/5 * * * *')          // Vérifie le dépôt Git toutes les 5 min
    }

    stages {

        // ══════════════════════════════════════════════════════════
        // ÉTAPE 1 : RÉCUPÉRATION DU CODE SOURCE
        // ══════════════════════════════════════════════════════════
        stage('📥 Checkout') {
            steps {
                echo "━━━ Récupération du code source ━━━"
                checkout scm
                echo "✅ Code récupéré depuis : ${env.GIT_URL}"
                echo "🔖 Branche : ${env.GIT_BRANCH}"
                echo "🔑 Commit  : ${env.GIT_COMMIT}"
            }
        }

        // ══════════════════════════════════════════════════════════
        // ÉTAPE 2 : COMPILATION
        // ══════════════════════════════════════════════════════════
        stage('🔨 Build') {
            steps {
                echo "━━━ Compilation du projet Maven ━━━"
                sh 'mvn clean compile -q'
                echo "✅ Compilation réussie !"
            }
            post {
                failure {
                    echo "❌ ÉCHEC DE COMPILATION — Vérifiez les erreurs ci-dessus."
                }
            }
        }

        // ══════════════════════════════════════════════════════════
        // ÉTAPE 3 : TESTS UNITAIRES + COUVERTURE
        // ══════════════════════════════════════════════════════════
        stage('🧪 Tests') {
            steps {
                echo "━━━ Exécution des tests unitaires JUnit 5 ━━━"
                sh 'mvn test'
                echo "✅ Tests terminés !"
            }
            post {
                always {
                    // Publie les résultats JUnit dans le tableau de bord Jenkins
                    junit '**/target/surefire-reports/*.xml'
                    echo "📊 Rapport JUnit publié dans Jenkins."
                }
                failure {
                    echo "❌ CERTAINS TESTS ONT ÉCHOUÉ — Consultez le rapport JUnit."
                }
            }
        }

        // ══════════════════════════════════════════════════════════
        // ÉTAPE 4 : RAPPORT DE COUVERTURE DE CODE (JaCoCo)
        // ══════════════════════════════════════════════════════════
        stage('📈 Couverture de Code') {
            steps {
                echo "━━━ Génération du rapport JaCoCo ━━━"
                sh 'mvn jacoco:report'
            }
            post {
                always {
                    // Publie le rapport de couverture (nécessite le plugin JaCoCo)
                    jacoco(
                        execPattern: '**/target/jacoco.exec',
                        classPattern: '**/target/classes',
                        sourcePattern: '**/src/main/java',
                        minimumLineCoverage: '70'
                    )
                    echo "📊 Rapport de couverture JaCoCo publié."
                }
            }
        }

        // ══════════════════════════════════════════════════════════
        // ÉTAPE 5 : PACKAGING (création du JAR)
        // ══════════════════════════════════════════════════════════
        stage('📦 Package') {
            steps {
                echo "━━━ Création du fichier JAR ━━━"
                sh 'mvn package -DskipTests -q'
                echo "✅ JAR créé : target/${PROJET}-${VERSION}.jar"
            }
            post {
                success {
                    // Archive le JAR comme artefact Jenkins
                    archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
                    echo "📁 Artefact archivé dans Jenkins."
                }
            }
        }

        // ══════════════════════════════════════════════════════════
        // ÉTAPE 6 : SIMULATION DE DÉPLOIEMENT
        // ══════════════════════════════════════════════════════════
        stage('🚀 Deploy (Simulation)') {
            when {
                branch 'main'           // Ne déploie que depuis la branche main
            }
            steps {
                echo "━━━ Simulation de déploiement ━━━"
                echo "🚀 Déploiement de ${PROJET} v${VERSION} en environnement de STAGING..."
                sh 'echo "Déploiement simulé avec succès !" && sleep 2'
                echo "✅ Application disponible sur http://staging.demo.local:8080"
            }
        }
    }

    // ─── Actions POST-PIPELINE ────────────────────────────────────
    post {
        success {
            echo """
            ╔══════════════════════════════════════╗
            ║   ✅  PIPELINE RÉUSSI                ║
            ║   Projet  : ${PROJET}               
            ║   Version : ${VERSION}              
            ║   Build   : #${env.BUILD_NUMBER}    
            ╚══════════════════════════════════════╝
            """
        }
        failure {
            echo """
            ╔══════════════════════════════════════╗
            ║   ❌  PIPELINE EN ÉCHEC              ║
            ║   Build : #${env.BUILD_NUMBER}       
            ║   → Consultez les logs ci-dessus     
            ╚══════════════════════════════════════╝
            """
        }
        always {
            echo "⏱️  Durée totale du build : ${currentBuild.durationString}"
            cleanWs()   // Nettoie l'espace de travail après le build
        }
    }
}
